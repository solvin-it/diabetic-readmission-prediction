FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN useradd -m appuser

COPY app/requirements.ui.txt /tmp/requirements.ui.txt
RUN pip install --no-cache-dir -r /tmp/requirements.ui.txt

COPY app /app/app

RUN chown -R appuser:appuser /app
USER appuser

EXPOSE 8501

CMD ["streamlit", "run", "app/ui/Home.py", "--server.port", "8501", "--server.address", "0.0.0.0"]
