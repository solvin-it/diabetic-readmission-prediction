# Diabetic Readmission Prediction — Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# OpenAI Integration (required for explanation chatbot)
# ============================================================================
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5.4-nano

# ============================================================================
# LangSmith Integration (optional; for tracing and debugging LLM calls)
# ============================================================================
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2_pt_your-key-here
LANGSMITH_WORKSPACE_ID=your-workspace-id

# ============================================================================
# API Configuration (optional; for local development)
# ============================================================================
# API_BASE_URL=http://localhost:8000
# LOG_LEVEL=INFO
